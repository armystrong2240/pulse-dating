# Production environment template
NODE_ENV=production
LOG_LEVEL=info
PORT=4000

# Comma-separated frontend origins
CLIENT_URL=https://www.pulsedate.net
ADMIN_EMAILS=security-admin@pulsedate.net

# Postgres URL used by runtime
DATABASE_URL=postgresql://app_user:change_me@db-host:5432/pulsedate?sslmode=require

# Optional override used by postgres prisma scripts
DATABASE_URL_POSTGRES=postgresql://app_user:change_me@db-host:5432/pulsedate?sslmode=require

# Must be unique and >= 32 characters
JWT_SECRET=replace_with_a_long_random_secret_value_32_chars_min
REFRESH_SECRET=replace_with_another_long_random_secret_32_chars_min
BCRYPT_ROUNDS=12
DATA_ENCRYPTION_KEY=replace_with_a_long_random_data_encryption_key_32_chars_min

# Retention policy controls (days)
RETENTION_REFRESH_GRACE_DAYS=7
RETENTION_VERIFY_TOKEN_DAYS=7
RETENTION_SECURITY_EVENT_DAYS=180

# Optional object storage (recommended for production media)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=pulsedate-media
