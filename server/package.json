    "axios": "^1.16.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.4.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "lowdb": "^7.0.1",
    "multer": "^2.1.1",
    "nanoid": "^3.3.12",
    "nodemailer": "^8.0.7",
    "resend": "^6.12.2",
    "socket.io": "^4.8.3",
    "uuid": "^14.0.0",
    "web-push": "^3.6.7",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.14",
    "prisma": "^6.19.3"
  },
  "optionalDependencies": {
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "better-sqlite3": "^12.9.0"
  },
