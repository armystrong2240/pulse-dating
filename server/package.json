{
  "name": "server",
  "version": "1.0.0",
  "main": "src/index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "preflight:prod": "node scripts/preflight-prod.mjs",
    "start:prod": "npm run preflight:prod && npm run db:migrate:postgres && npm run db:seed:postgres && npm run start",
    "db:seed:postgres": "node scripts/seed-postgres.mjs",
    "db:migrate:resolve": "node scripts/prisma-postgres.mjs migrate resolve --rolled-back 0001_init || true",
    "db:generate": "prisma generate",
    "db:generate:postgres": "node scripts/prisma-postgres.mjs generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:postgres": "node scripts/prisma-postgres.mjs migrate deploy",
    "db:status": "prisma migrate status",
    "db:status:postgres": "node scripts/prisma-postgres.mjs migrate status",
    "maintenance:retention": "node scripts/maintenance-retention.mjs",
    "db:seed": "node prisma/seed.js",
    "db:setup": "prisma migrate deploy && node prisma/seed.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "Dating app backend",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1040.0",
