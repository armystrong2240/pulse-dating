generator client {
  provider = "prisma-client-js"
  output   = "../../generated/postgres-client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL_POSTGRES")
}

model User {
  id                  String    @id @default(uuid())
  email               String    @unique
  passwordHash        String
  name                String
  age                 Int
  city                String
  state               String    @default("")
  zipCode             String    @default("")
  pronouns            String    @default("")
  genderIdentity      String    @default("")
  sexualOrientation   String    @default("")
  polyPreference      String    @default("")
  bio                 String
  interests           String    @default("[]") // JSON array stored as string for SQLite
  lookingFor          String    @default("Open to meeting people")
  profileTheme        String    @default("sunset")
  profileGraphic      String    @default("none")
  musicUrl            String    @default("")
  profileMotto        String    @default("")
  dreamDate           String    @default("")
  avatar              String    @default("")
  latitude            Float     @default(0)
  longitude           Float     @default(0)
  profilePrompts      String    @default("[]") // JSON [{q,a}]
  verified            Boolean   @default(false)
  verifiedStatus      String    @default("") // "" | "pending" | "verified"
  paused              Boolean   @default(false)
  boostedUntil        DateTime?
  isPremium           Boolean   @default(false)
  premiumTier         String    @default("free")
  boostCredits        Int       @default(0)
  roseBalance         Int       @default(0)
  loginStreak         Int       @default(0)
  lastLoginDate       String    @default("")
  phoneNumber         String?   @unique
  phoneVerified       Boolean   @default(false)
  autoHidden          Boolean   @default(false)
  profileScore        Int       @default(0)
  profileVisibility   String    @default("{}") // JSON: hidden field keys
  onboardingStep      String    @default("basics")
  onboardingCompleted Boolean   @default(false)
  emailVerified       Boolean   @default(false)
  verifyToken         String?
  resetToken          String?   @unique
  resetTokenExpiry    DateTime?
  pushSubscription    String?
  referralCode        String?   @unique
  referredById        String?
  lastSeen            DateTime?
  createdAt           DateTime  @default(now())

  media                  Media[]
  likesSent              Like[]              @relation("LikeFrom")
  likesReceived          Like[]              @relation("LikeTo")
  messages               Message[]
  messageReactions       MessageReaction[]
  liveRooms              LiveRoom[]
  refreshTokens          RefreshToken[]
  dailyLikes             DailyLike[]
  viewsGiven             ProfileView[]       @relation("ViewsGiven")
  viewsReceived          ProfileView[]       @relation("ViewsReceived")
  blocksGiven            BlockedUser[]       @relation("BlocksGiven")
  blocksReceived         BlockedUser[]       @relation("BlocksReceived")
  reports                Report[]            @relation("ReportsMade")
  securityEvents         SecurityEvent[]
  friendRequestsSent     Friendship[]        @relation("FriendRequestsSent")
  friendRequestsReceived Friendship[]        @relation("FriendRequestsReceived")
  subscription           Subscription?
  giftsGiven             Gift[]              @relation("GiftsGiven")
  giftsReceived          Gift[]              @relation("GiftsReceived")
  referrals              Referral[]          @relation("ReferralsMade")
  roseLedger             RoseLedger[]
  phoneVerifications     PhoneVerification[]
  scheduledBoosts        ScheduledBoost[]

  @@index([latitude, longitude])
}

model Media {
  id         String   @id @default(uuid())
  userId     String
  type       String
  url        String
  sortOrder  Int      @default(0)
  uploadedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Like {
  id        String   @id @default(uuid())
  fromId    String
  toId      String
  liked     Boolean
  superLike Boolean  @default(false)
  createdAt DateTime @default(now())

  from User @relation("LikeFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to   User @relation("LikeTo", fields: [toId], references: [id], onDelete: Cascade)

  @@unique([fromId, toId])
}

model ProfileView {
  id       String   @id @default(uuid())
  viewerId String
  viewedId String
  viewedAt DateTime @default(now())

  viewer User @relation("ViewsGiven", fields: [viewerId], references: [id], onDelete: Cascade)
  viewed User @relation("ViewsReceived", fields: [viewedId], references: [id], onDelete: Cascade)

  @@unique([viewerId, viewedId])
}

model Message {
  id         String    @id @default(uuid())
  senderId   String
  senderName String
  roomId     String
  text       String    @default("")
  imageUrl   String?
  readAt     DateTime?
  createdAt  DateTime  @default(now())

  sender    User              @relation(fields: [senderId], references: [id], onDelete: Cascade)
  reactions MessageReaction[]
}

model MessageReaction {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
}

model BlockedUser {
  id        String   @id @default(uuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  blocker User @relation("BlocksGiven", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("BlocksReceived", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
}

model Report {
  id         String   @id @default(uuid())
  reporterId String
  reportedId String
  reason     String
  details    String   @default("")
  createdAt  DateTime @default(now())

  reporter User @relation("ReportsMade", fields: [reporterId], references: [id], onDelete: Cascade)
}

model Friendship {
  id          String   @id @default(uuid())
  requesterId String
  addresseeId String
  status      String   @default("pending") // pending | accepted | declined
  createdAt   DateTime @default(now())

  requester User @relation("FriendRequestsSent", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee User @relation("FriendRequestsReceived", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
}

model LiveRoom {
  id        String   @id @default(uuid())
  hostId    String
  hostName  String
  title     String
  startedAt DateTime @default(now())
  active    Boolean  @default(true)
  viewers   Int      @default(0)

  host User @relation(fields: [hostId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DailyLike {
  id     String @id @default(uuid())
  userId String
  date   String // YYYY-MM-DD
  count  Int    @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model SecurityEvent {
  id        String   @id @default(uuid())
  userId    String?
  email     String?
  eventType String
  severity  String   @default("info")
  ip        String?
  userAgent String?
  metadata  String   @default("{}")
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([eventType])
  @@index([userId])
}

model Subscription {
  id                   String    @id @default(uuid())
  userId               String    @unique
  stripeCustomerId     String    @unique
  stripeSubscriptionId String?
  stripePriceId        String?
  tier                 String    @default("free")
  status               String    @default("active")
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Gift {
  id        String   @id @default(uuid())
  fromId    String
  toId      String
  giftType  String
  message   String   @default("")
  seen      Boolean  @default(false)
  createdAt DateTime @default(now())

  from User @relation("GiftsGiven", fields: [fromId], references: [id], onDelete: Cascade)
  to   User @relation("GiftsReceived", fields: [toId], references: [id], onDelete: Cascade)

  @@index([toId])
  @@index([fromId])
}

model Referral {
  id          String   @id @default(uuid())
  referrerId  String
  refereeId   String   @unique
  rewardGiven Boolean  @default(false)
  createdAt   DateTime @default(now())

  referrer User @relation("ReferralsMade", fields: [referrerId], references: [id], onDelete: Cascade)

  @@index([referrerId])
}

model RoseLedger {
  id        String   @id @default(uuid())
  userId    String
  delta     Int
  reason    String
  refId     String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PhoneVerification {
  id        String   @id @default(uuid())
  userId    String
  phone     String
  code      String
  expiresAt DateTime
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ScheduledBoost {
  id          String   @id @default(uuid())
  userId      String
  scheduledAt DateTime
  durationMin Int      @default(30)
  fired       Boolean  @default(false)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([scheduledAt])
}
