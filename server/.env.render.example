# Render production template
NODE_ENV=production
LOG_LEVEL=info
PORT=4000
CLIENT_URL=https://your-client-domain.com
ADMIN_EMAILS=security-admin@your-company.com

DATABASE_URL=postgresql://app_user:change_me@render-postgres-host:5432/pulsedate?sslmode=require
DATABASE_URL_POSTGRES=postgresql://app_user:change_me@render-postgres-host:5432/pulsedate?sslmode=require

JWT_SECRET=replace_with_a_long_random_secret_value_32_chars_min
REFRESH_SECRET=replace_with_another_long_random_secret_32_chars_min
BCRYPT_ROUNDS=12
DATA_ENCRYPTION_KEY=replace_with_a_long_random_data_encryption_key_32_chars_min

RETENTION_REFRESH_GRACE_DAYS=7
RETENTION_VERIFY_TOKEN_DAYS=7
RETENTION_SECURITY_EVENT_DAYS=180

# Billing providers
# PayPal subscriptions
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_PLAN_PLUS_ID=
PAYPAL_PLAN_GOLD_ID=
# Stripe card subscriptions
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PLUS_ID=
STRIPE_PRICE_GOLD_ID=
