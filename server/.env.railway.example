# Railway production template
NODE_ENV=production
LOG_LEVEL=info
PORT=4000
CLIENT_URL=https://www.pulsedate.net
ADMIN_EMAILS=security-admin@pulsedate.net
# Optional emergency password reset for ADMIN_EMAILS on startup.
# Set once, deploy, login, then remove and redeploy.
ADMIN_BOOTSTRAP_PASSWORD=

# Prefer Railway's Postgres URL variable reference in dashboard
# Example value in Railway Variables panel:
# DATABASE_URL=${{Postgres.DATABASE_URL}}
DATABASE_URL=postgresql://app_user:change_me@railway-host:5432/pulsedate?sslmode=require
DATABASE_URL_POSTGRES=postgresql://app_user:change_me@railway-host:5432/pulsedate?sslmode=require

JWT_SECRET=replace_with_a_long_random_secret_value_32_chars_min
REFRESH_SECRET=replace_with_another_long_random_secret_32_chars_min
BCRYPT_ROUNDS=12
DATA_ENCRYPTION_KEY=replace_with_a_long_random_data_encryption_key_32_chars_min

RETENTION_REFRESH_GRACE_DAYS=7
RETENTION_VERIFY_TOKEN_DAYS=7
RETENTION_SECURITY_EVENT_DAYS=180
