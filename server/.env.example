# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string (required in production)
# Local:   postgresql://postgres:password@localhost:5432/pulsedate
# Railway: auto-injected via ${{Postgres.DATABASE_URL}}
# Neon:    postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/pulsedate?sslmode=require
DATABASE_URL="postgresql://postgres:password@localhost:5432/pulsedate"

# Optional override used by postgres Prisma scripts. If omitted, DATABASE_URL is used.
DATABASE_URL_POSTGRES="postgresql://postgres:password@localhost:5432/pulsedate"

# Dev SQLite example (development/test only):
# DATABASE_URL="file:./data/demo.db"

# ── Auth secrets (change both in production!) ─────────────────────────────────
# In production both secrets must be unique and at least 32 chars.
JWT_SECRET="change_me_to_a_long_random_string"
REFRESH_SECRET="change_me_to_a_different_long_random_string"
# BCrypt rounds: production enforces minimum effective value of 12.
BCRYPT_ROUNDS=12
# Data encryption key for sensitive at-rest fields (>=32 chars).
DATA_ENCRYPTION_KEY="change_me_to_a_long_random_data_encryption_key"

# Retention policy controls (days)
RETENTION_REFRESH_GRACE_DAYS=7
RETENTION_VERIFY_TOKEN_DAYS=7
RETENTION_SECURITY_EVENT_DAYS=180

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
LOG_LEVEL=info

# Comma-separated list of allowed frontend origins
# Example: "https://app.example.com,https://admin.example.com"
CLIENT_URL="http://localhost:5173"
# Comma-separated admin emails for security monitoring endpoints
ADMIN_EMAILS="admin@example.com"

# ── Media Storage (optional — falls back to local /uploads folder) ─────────────
# Create an S3 bucket (or Cloudflare R2) and fill these in for production
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=pulsedate-media
